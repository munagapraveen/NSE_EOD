# Database URL for PostgreSQL
DATABASE_URL=postgresql://nse_user:secure_password_here@localhost:5432/nse_eod

# NSE Data Sync Configurations
NSE_START_DATE=2024-01-01
NSE_REQUEST_DELAY_SECONDS=3.0
NSE_SESSION_REFRESH_MINUTES=5
NSE_MAX_RETRIES=3

# UI/App Settings
APP_TITLE=NSE EOD Data Manager
APP_HOST=127.0.0.1
APP_PORT=8080
APP_NATIVE=true
APP_DARK_MODE=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=data/logs/app.log

# Background Auto-Sync Schedule
AUTO_SYNC_ENABLED=false
AUTO_SYNC_TIME=18:30

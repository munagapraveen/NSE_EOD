import json
import os
from datetime import date, timedelta, datetime
from typing import Set, List
from loguru import logger
from src.services.nse_client import NSEClient


def get_calendar_days(start_date: date, end_date: date) -> List[date]:
    """
    Generate all calendar dates (inclusive) between start_date and end_date.
    """
    days = []
    current = start_date
    while current <= end_date:
        days.append(current)
        current += timedelta(days=1)
    return days


async def get_nse_holidays(client: NSEClient, cache_path: str = "data/holidays.json") -> Set[date]:
    """
    Fetch standard trading holidays from the NSE API.
    Caches the results to holidays.json and returns a set of date objects.
    """
    holidays = set()
    
    # Try fetching from API first
    try:
        logger.info("Fetching trading holidays from NSE API...")
        # Get date ranges from current year - 1 to current year + 1 to cover the required bounds
        current_year = date.today().year
        from_date = f"01-01-{current_year - 1}"
        to_date = f"31-12-{current_year + 1}"
        
        # Call NSE client for holiday master
        # The holiday-master endpoint is at https://www.nseindia.com/api/holiday-master?type=trading
        response = await client._get(
            "https://www.nseindia.com/api/holiday-master?type=trading",
            requires_cookies=True
        )
        data = response.json()
        
        # Typical structure has key "CM" or "trading"
        # Let's inspect "CM" segment which is capital markets (equity)
        raw_holidays = []
        if isinstance(data, dict):
            # Sometimes it's a dict containing segments like "CM" (Capital Market)
            if "CM" in data:
                raw_holidays = data["CM"]
            elif "trading" in data:
                raw_holidays = data["trading"]
            else:
                # Fallback: check values that are lists
                for val in data.values():
                    if isinstance(val, list):
                        raw_holidays = val
                        break
        elif isinstance(data, list):
            raw_holidays = data
 
        parsed_holiday_strs = []
        for h in raw_holidays:
            if isinstance(h, dict) and "tradingDate" in h:
                # Format: "01-Jan-2026"
                date_str = h["tradingDate"]
                try:
                    dt = datetime.strptime(date_str, "%d-%b-%Y").date()
                    holidays.add(dt)
                    parsed_holiday_strs.append(dt.isoformat())
                except Exception as e:
                    logger.warning(f"Could not parse holiday date string '{date_str}': {e}")
                    
        if parsed_holiday_strs:
            # Cache to file
            os.makedirs(os.path.dirname(cache_path), exist_ok=True)
            with open(cache_path, "w") as f:
                json.dump(parsed_holiday_strs, f)
            logger.info(f"Successfully cached {len(holidays)} holidays to {cache_path}")
            return holidays
            
    except Exception as e:
        logger.error(f"Failed to fetch trading holidays from NSE API: {e}")

    # Fallback to local cache
    if os.path.exists(cache_path):
        try:
            logger.info(f"Loading holidays from local cache: {cache_path}")
            with open(cache_path, "r") as f:
                cached_strs = json.load(f)
            for s in cached_strs:
                holidays.add(date.fromisoformat(s))
            logger.info(f"Loaded {len(holidays)} holidays from cache.")
            return holidays
        except Exception as cache_err:
            logger.error(f"Failed to read local holiday cache: {cache_err}")

    # Hardcoded fallback list for standard national holidays
    logger.warning("Using static hardcoded national holidays as fallback")
    current_year = date.today().year
    years = [current_year - 2, current_year - 1, current_year, current_year + 1]
    
    # Standard static holidays (Republic Day, Independence Day, Gandhi Jayanti, Christmas)
    for year in years:
        holidays.add(date(year, 1, 26))   # Republic Day
        holidays.add(date(year, 8, 15))   # Independence Day
        holidays.add(date(year, 10, 2))   # Gandhi Jayanti
        holidays.add(date(year, 12, 25))  # Christmas
        
    return holidays
